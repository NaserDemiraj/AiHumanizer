generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum VerificationTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model User {
  id              String               @id @default(cuid())
  email           String               @unique
  name            String
  passwordHash    String
  emailVerified   Boolean              @default(false)
  plan            Plan                 @default(FREE)
  wordsUsed       Int                  @default(0)
  ocrPagesUsed    Int                  @default(0)
  conversionsUsed Int                  @default(0)
  storageBytes    BigInt               @default(0)
  periodStart     DateTime             @default(now())
  createdAt       DateTime             @default(now())
  sessions        Session[]
  documents       Document[]
  projects        Project[]
  activities      Activity[]
  apiKeys         ApiKey[]
  verificationTokens VerificationToken[]
}

model VerificationToken {
  id        String                @id @default(cuid())
  token     String                @unique
  type      VerificationTokenType
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  @@index([userId, type])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Project {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime   @default(now())
  documents Document[]

  @@index([userId])
}

model Document {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title        String
  kind         String    @default("humanize")
  originalText String
  improvedText String?
  /// Rich editor content (Tiptap/ProseMirror JSON) for kind "editor" docs
  content      Json?
  /// Storage key of the uploaded original file, if any
  sourcePath   String?
  /// Detected format of the uploaded original (pdf, docx, doc, rtf, odt, txt, md, png, …)
  sourceFormat String?
  /// Size in bytes of the stored original — reclaimed from the user's quota on delete
  sourceBytes  Int?
  mode         String    @default("Humanize")
  metrics      Json?
  favorite     Boolean   @default(false)
  tags         String[]  @default([])
  /// Soft delete — trash/restore
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  versions     DocumentVersion[]

  @@index([userId, createdAt])
  @@index([projectId])
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  /// User-editable label, defaults to the operation that created it
  label      String
  /// The operation that produced this version (manual-edit, humanize, grammar, …)
  op         String
  /// Plain-text snapshot (always present, used for diffs)
  text       String
  /// Rich content snapshot when the version came from the editor
  content    Json?
  metrics    Json?
  createdAt  DateTime @default(now())

  @@index([documentId, createdAt])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  detail    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  prefix     String
  keyHash    String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}
