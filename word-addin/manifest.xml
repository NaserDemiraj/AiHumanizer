<?xml version="1.0" encoding="UTF-8"?>
<!--
  HumanFlow Word add-in (task pane). Sideload for development:
    Word → Insert → My Add-ins → Upload My Add-in → pick this manifest.xml
  The Source Location below must be served over https for production; for
  local dev, host the word-addin/ folder over https (see README).
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="TaskPaneApp">

  <Id>b6f2e1a4-9c3d-4f8a-bb21-7e5d9f0c1a22</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>HumanFlow</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="HumanFlow" />
  <Description DefaultValue="Humanize, rewrite, fix grammar, paraphrase, summarize, and translate the selected text in your document." />
  <IconUrl DefaultValue="https://localhost:3000/word-addin/icons/icon32.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/word-addin/icons/icon128.png" />
  <SupportUrl DefaultValue="https://localhost:3000" />

  <Hosts>
    <Host Name="Document" />
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.3">
      <Set Name="WordApi" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/word-addin/taskpane.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
